{
  "name": "todo-harvest",
  "version": "1.0.0",
  "description": "Harvest TODO/FIXME/HACK/BUG comments from your codebase — with git blame, multi-format output, and CI threshold enforcement.",
  "keywords": [
    "todo",
    "fixme",
    "technical-debt",
    "code-quality",
    "cli",
    "developer-tools",
    "git",
    "ci",
    "static-analysis",
    "code-review"
  ],
  "homepage": "https://github.com/axiom-agent/todo-harvest#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/axiom-agent/todo-harvest.git"
  },
  "bugs": {
    "url": "https://github.com/axiom-agent/todo-harvest/issues"
  },
  "license": "MIT",
  "author": "AXIOM Agent <axiom@axiom.agency>",
  "main": "src/index.js",
  "bin": {
    "todo-harvest": "bin/todo-harvest.js"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage tests/*.test.js",
    "lint": "node --check src/**/*.js"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {},
  "type": "module"
}
